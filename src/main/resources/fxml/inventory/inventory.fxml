<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.possystem.sajilopos.controller.inventory.inventorycontroller"
            prefWidth="1200" prefHeight="800"
            style="-fx-background-color: #f1f5f9;">

    <!-- TOP HEADER -->
    <top>
        <VBox style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
            <children>
                <!-- Title Bar -->
                <HBox prefHeight="70">
                    <children>
                        <Label text="INVENTORY MANAGEMENT"
                               style="-fx-font-size: 26px; -fx-font-weight: bold;">
                            <HBox.margin>
                                <Insets top="20" left="25"/>
                            </HBox.margin>
                        </Label>
                    </children>
                </HBox>

                <!-- Search Bar -->
                <HBox spacing="10" style="-fx-padding: 10 25;">
                    <children>
                        <Label text="Search Product:" style="-fx-font-size: 14px;">
                            <HBox.margin>
                                <Insets top="5"/>
                            </HBox.margin>
                        </Label>
                        <TextField fx:id="searchField" promptText="Enter product name..." prefWidth="300"/>
                        <Button text="Search" onAction="#handleSearch"
                                style="-fx-background-color: #3b82f6; -fx-text-fill: white;"/>
                        <Button text="Refresh" onAction="#handleRefresh"
                                style="-fx-background-color: #10b981; -fx-text-fill: white;"/>
                        <Button text="Show Low Stock" onAction="#handleShowLowStock"
                                style="-fx-background-color: #f59e0b; -fx-text-fill: white;"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <!-- CENTER CONTENT -->
    <center>
        <VBox spacing="15" style="-fx-padding: 20;">
            <children>
                <!-- Current Inventory Section -->
                <VBox spacing="10" VBox.vgrow="ALWAYS">
                    <children>
                        <HBox>
                            <children>
                                <Label text="Current Inventory"
                                       style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="Adjust Stock" onAction="#handleAdjustStock"
                                        style="-fx-background-color: #8b5cf6; -fx-text-fill: white;"/>
                                <Button text="Record Purchase" onAction="#handleRecordPurchase"
                                        style="-fx-background-color: #06b6d4; -fx-text-fill: white;">
                                    <HBox.margin>
                                        <Insets left="10"/>
                                    </HBox.margin>
                                </Button>
                            </children>
                        </HBox>

                        <TableView fx:id="inventoryTable" VBox.vgrow="ALWAYS"
                                   style="-fx-background-color: white;">
                            <columns>
                                <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                                <TableColumn fx:id="colProduct" text="Product" prefWidth="300"/>
                                <TableColumn fx:id="colPrice" text="Price" prefWidth="120"/>
                                <TableColumn fx:id="colStock" text="Stock" prefWidth="100"/>
                                <TableColumn fx:id="colStatus" text="Status" prefWidth="150"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>

                <!-- Recent Activity Section -->
                <VBox spacing="10" prefHeight="250">
                    <children>
                        <Label text="Recent Activity"
                               style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

                        <TableView fx:id="historyTable" prefHeight="200"
                                   style="-fx-background-color: white;">
                            <columns>
                                <TableColumn fx:id="colHistoryProduct" text="Product" prefWidth="300"/>
                                <TableColumn fx:id="colAction" text="Action" prefWidth="150"/>
                                <TableColumn fx:id="colQty" text="Qty" prefWidth="100"/>
                                <TableColumn fx:id="colDate" text="Date" prefWidth="180"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>

    <!-- LEGEND AT BOTTOM -->
    <bottom>
        <HBox spacing="20" style="-fx-background-color: white; -fx-padding: 15 25; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0;">
            <children>
                <Label text="Legend:" style="-fx-font-weight: bold;"/>
                <HBox spacing="5">
                    <children>
                        <Label text="■" style="-fx-text-fill: #ef4444; -fx-font-size: 16px;"/>
                        <Label text="Out of Stock"/>
                    </children>
                </HBox>
                <HBox spacing="5">
                    <children>
                        <Label text="■" style="-fx-text-fill: #f59e0b; -fx-font-size: 16px;"/>
                        <Label text="Low Stock"/>
                    </children>
                </HBox>
                <HBox spacing="5">
                    <children>
                        <Label text="■" style="-fx-text-fill: #10b981; -fx-font-size: 16px;"/>
                        <Label text="Normal"/>
                    </children>
                </HBox>
            </children>
        </HBox>
    </bottom>

</BorderPane>
