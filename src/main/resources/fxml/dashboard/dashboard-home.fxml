<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>

<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:id="dashboardRoot"
            fx:controller="com.possystem.sajilopos.controller.dashboard.DashboardHomeController"
            style="-fx-background-color: #f5f7fb;">

    <children>
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    AnchorPane.topAnchor="0"
                    AnchorPane.bottomAnchor="0"
                    AnchorPane.leftAnchor="0"
                    AnchorPane.rightAnchor="0"
                    style="-fx-background-color: transparent;">
            <content>
                <VBox spacing="20" style="-fx-background-color: #f5f7fb;">
                    <padding>
                        <Insets top="24" right="24" bottom="24" left="24"/>
                    </padding>

                    <!-- Top Section - Business Overview -->
                    <VBox spacing="12">
                        <Label text="Business Overview"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                        <GridPane hgap="16" vgap="16">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                                <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints vgrow="ALWAYS"/>
                                <RowConstraints vgrow="ALWAYS"/>
                            </rowConstraints>

                            <VBox GridPane.rowIndex="0" GridPane.columnIndex="0" spacing="6"
                                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 16; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),8,0,0,2);">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="💵" style="-fx-font-size: 16px;"/>
                                    <Label text="Today's Revenue" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                                </HBox>
                                <Label fx:id="todayRevenueLabel" text="Rs. 0"
                                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                                <Label fx:id="todayRevenueTrendLabel" text="--"
                                       style="-fx-font-size: 11px; -fx-text-fill: #64748b;"/>
                            </VBox>

                            <VBox GridPane.rowIndex="0" GridPane.columnIndex="1" spacing="6"
                                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 16; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),8,0,0,2);">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="🧾" style="-fx-font-size: 16px;"/>
                                    <Label text="Transactions Today" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                                </HBox>
                                <Label fx:id="transactionsTodayLabel" text="0"
                                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                                <Label fx:id="transactionsTrendLabel" text="--"
                                       style="-fx-font-size: 11px; -fx-text-fill: #64748b;"/>
                            </VBox>

                            <VBox GridPane.rowIndex="1" GridPane.columnIndex="0" spacing="6"
                                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 16; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),8,0,0,2);">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="📦" style="-fx-font-size: 16px;"/>
                                    <Label text="Products Sold" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                                </HBox>
                                <Label fx:id="productsSoldLabel" text="0"
                                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                                <Label fx:id="productsSoldTrendLabel" text="--"
                                       style="-fx-font-size: 11px; -fx-text-fill: #64748b;"/>
                            </VBox>

                            <VBox GridPane.rowIndex="1" GridPane.columnIndex="1" spacing="6"
                                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 16; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),8,0,0,2);">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="⚠" style="-fx-font-size: 16px;"/>
                                    <Label text="Low Stock Products" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                                </HBox>
                                <Label fx:id="lowStockCountLabel" text="0"
                                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                                <Label fx:id="lowStockTrendLabel" text="--"
                                       style="-fx-font-size: 11px; -fx-text-fill: #64748b;"/>
                            </VBox>
                        </GridPane>
                    </VBox>

                    <!-- Second Row - Analytics -->
                    <HBox spacing="16">
                        <VBox spacing="12" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 16; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),8,0,0,2);">
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="Sales Analytics" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                                <HBox spacing="6">
                                    <ToggleButton fx:id="rangeTodayToggle" text="Today" />
                                    <ToggleButton fx:id="rangeWeekToggle" text="Week" />
                                    <ToggleButton fx:id="rangeMonthToggle" text="Month" />
                                </HBox>
                            </HBox>
                            <LineChart fx:id="salesLineChart" prefHeight="220" animated="false" legendVisible="false">
                                <xAxis>
                                    <CategoryAxis />
                                </xAxis>
                                <yAxis>
                                    <NumberAxis />
                                </yAxis>
                            </LineChart>
                        </VBox>
                    </HBox>

                    <!-- Quick Actions -->
                    <HBox spacing="16">
                        <VBox spacing="10" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 16; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),8,0,0,2);">
                            <Label text="Quick Actions" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                            <HBox spacing="12">
                                <Button text="➕  New Sale" onAction="#goToSales" prefHeight="38" HBox.hgrow="ALWAYS"
                                        style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;"/>
                                <Button text="📦  Add Product" onAction="#goToProducts" prefHeight="38" HBox.hgrow="ALWAYS"
                                        style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;"/>
                                <Button text="📊  Reports" onAction="#goToReports" prefHeight="38" HBox.hgrow="ALWAYS"
                                        style="-fx-background-color: #7c3aed; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;"/>
                            </HBox>
                        </VBox>
                    </HBox>






                    <!-- Footer Summary -->
                    <HBox spacing="16">
                        <VBox spacing="4" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 12 16; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),6,0,0,2);">
                            <Label text="Total Products" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                            <Label fx:id="totalProductsLabel" text="0"
                                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 12 16; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),6,0,0,2);">
                            <Label text="Total Customers" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                            <Label fx:id="totalCustomersLabel" text="0"
                                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 12 16; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),6,0,0,2);">
                            <Label text="Total Suppliers" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                            <Label fx:id="totalSuppliersLabel" text="0"
                                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 12 16; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),6,0,0,2);">
                            <Label text="Total Inventory Value" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                            <Label fx:id="totalInventoryValueLabel" text="Rs. 0"
                                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                        </VBox>
                    </HBox>

                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>
