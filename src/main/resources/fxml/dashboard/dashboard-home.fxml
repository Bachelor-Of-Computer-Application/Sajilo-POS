<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.possystem.sajilopos.controller.dashboard.DashboardHomeController"
            style="-fx-background-color: #f1f5f9;">

    <children>

        <!-- CARD 1 -->
        <VBox layoutX="40" layoutY="40"
              prefWidth="220" prefHeight="120"
              style="-fx-background-color: white; -fx-background-radius: 15;">

            <children>
                <Label text="Total Sales"
                       style="-fx-font-size: 14px;">
                    <VBox.margin>
                        <Insets top="20" left="20"/>
                    </VBox.margin>
                </Label>

                <Label fx:id="totalSalesLabel"
                       text="Rs. 0.00"
                       style="-fx-font-size: 28px; -fx-font-weight: bold;">
                    <VBox.margin>
                        <Insets top="10" left="20"/>
                    </VBox.margin>
                </Label>
            </children>
        </VBox>

        <!-- CARD 2 -->
        <VBox layoutX="300" layoutY="40"
              prefWidth="220" prefHeight="120"
              style="-fx-background-color: white; -fx-background-radius: 15;">

            <children>
                <Label text="Transactions">
                    <VBox.margin>
                        <Insets top="20" left="20"/>
                    </VBox.margin>
                </Label>

                <Label fx:id="totalTransactionsLabel"
                       text="0"
                       style="-fx-font-size: 28px; -fx-font-weight: bold;">
                    <VBox.margin>
                        <Insets top="10" left="20"/>
                    </VBox.margin>
                </Label>
            </children>
        </VBox>

        <!-- CARD 3 -->
        <VBox layoutX="560" layoutY="40"
              prefWidth="220" prefHeight="120"
              style="-fx-background-color: white; -fx-background-radius: 15;">

            <children>
                <Label text="Low Stock Products">
                    <VBox.margin>
                        <Insets top="20" left="20"/>
                    </VBox.margin>
                </Label>

                <Label fx:id="lowStockLabel"
                       text="0"
                       style="-fx-font-size: 28px; -fx-font-weight: bold;">
                    <VBox.margin>
                        <Insets top="10" left="20"/>
                    </VBox.margin>
                </Label>
            </children>
        </VBox>

        <!-- RECENT SALES -->
        <VBox layoutX="40" layoutY="210"
              prefWidth="740" prefHeight="300"
              style="-fx-background-color: white; -fx-background-radius: 15;">

            <children>
                <Label text="Recent Sales"
                       style="-fx-font-size: 20px; -fx-font-weight: bold;">
                    <VBox.margin>
                        <Insets top="20" left="20"/>
                    </VBox.margin>
                </Label>

                <Label text="Invoice #1001 - Rs. 4500">
                    <VBox.margin>
                        <Insets top="20" left="20"/>
                    </VBox.margin>
                </Label>

                <Label text="Invoice #1002 - Rs. 7200">
                    <VBox.margin>
                        <Insets top="10" left="20"/>
                    </VBox.margin>
                </Label>

                <Label text="Invoice #1003 - Rs. 1500">
                    <VBox.margin>
                        <Insets top="10" left="20"/>
                    </VBox.margin>
                </Label>

            </children>
        </VBox>

        <!-- QUICK ACTIONS -->
        <VBox layoutX="820" layoutY="210"
              prefWidth="250" prefHeight="300"
              spacing="15"
              style="-fx-background-color: white; -fx-background-radius: 15;">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <children>
                <Label text="Quick Actions"
                       style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

                <Button text="Add Product"/>
                <Button text="Create Sale"/>
                <Button text="Generate Report"/>
            </children>

        </VBox>

    </children>
</AnchorPane>