<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.possystem.sajilopos.controller.dashboard.DashboardHomeController"
            style="-fx-background-color: #f1f5f9;">

    <children>

        <!-- ── SUMMARY CARDS ─────────────────────────────────────── -->

        <!-- Card: Today's Sales -->
        <VBox layoutX="40" layoutY="40"
              prefWidth="220" prefHeight="120"
              style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian,rgba(0,0,0,.08),8,0,0,2);">
            <padding><Insets top="20" left="20" right="20" bottom="20"/></padding>
            <Label text="Today's Sales"
                   style="-fx-font-size: 13px; -fx-text-fill: #64748b;"/>
            <Label fx:id="totalSalesLabel" text="Rs. 0"
                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
        </VBox>

        <!-- Card: Items Sold Today -->
        <VBox layoutX="300" layoutY="40"
              prefWidth="220" prefHeight="120"
              style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian,rgba(0,0,0,.08),8,0,0,2);">
            <padding><Insets top="20" left="20" right="20" bottom="20"/></padding>
            <Label text="Items Sold Today"
                   style="-fx-font-size: 13px; -fx-text-fill: #64748b;"/>
            <Label fx:id="totalProductsLabel" text="0"
                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
        </VBox>

        <!-- Card: Transactions Today -->
        <VBox layoutX="560" layoutY="40"
              prefWidth="220" prefHeight="120"
              style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian,rgba(0,0,0,.08),8,0,0,2);">
            <padding><Insets top="20" left="20" right="20" bottom="20"/></padding>
            <Label text="Transactions Today"
                   style="-fx-font-size: 13px; -fx-text-fill: #64748b;"/>
            <Label fx:id="totalCustomersLabel" text="0"
                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
        </VBox>

        <!-- ── RECENT SALES ──────────────────────────────────────── -->
        <VBox layoutX="40" layoutY="200"
              prefWidth="740" prefHeight="200"
              spacing="12"
              style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian,rgba(0,0,0,.08),8,0,0,2);">
            <padding><Insets top="20" left="20" right="20" bottom="20"/></padding>

            <Label text="Recent Sales"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>

            <Label fx:id="noSalesLabel" text="No sales today yet."
                   style="-fx-font-size: 13px; -fx-text-fill: #94a3b8;"
                   visible="false" managed="false"/>

            <Label fx:id="invoice1Label" text=""
                   style="-fx-font-size: 13px; -fx-text-fill: #334155;"
                   visible="false" managed="false"/>
            <Label fx:id="invoice2Label" text=""
                   style="-fx-font-size: 13px; -fx-text-fill: #334155;"
                   visible="false" managed="false"/>
            <Label fx:id="invoice3Label" text=""
                   style="-fx-font-size: 13px; -fx-text-fill: #334155;"
                   visible="false" managed="false"/>
        </VBox>

        <!-- ── QUICK ACTIONS ─────────────────────────────────────── -->
        <VBox layoutX="820" layoutY="200"
              prefWidth="250" prefHeight="200"
              spacing="12"
              style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian,rgba(0,0,0,.08),8,0,0,2);">
            <padding><Insets top="20" left="20" right="20" bottom="20"/></padding>

            <Label text="Quick Actions"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>

            <!-- These load views via the parent DashboardController — they are
                 intentionally left without onAction since this is a nested FXML.
                 Sidebar buttons serve the same navigation purpose. -->
            <Button text="➕  New Sale"    maxWidth="Infinity"
                    style="-fx-background-color:#2563eb; -fx-text-fill:white; -fx-background-radius:6; -fx-cursor:hand;"/>
            <Button text="📦  Add Product" maxWidth="Infinity"
                    style="-fx-background-color:#10b981; -fx-text-fill:white; -fx-background-radius:6; -fx-cursor:hand;"/>
            <Button text="📊  Reports"     maxWidth="Infinity"
                    style="-fx-background-color:#7c3aed; -fx-text-fill:white; -fx-background-radius:6; -fx-cursor:hand;"/>
        </VBox>

    </children>
</AnchorPane>
