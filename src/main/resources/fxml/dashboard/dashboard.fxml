<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.possystem.sajilopos.controller.dashboard.DashboardController"
            fx:id="rootPane"
            prefWidth="1400"
            prefHeight="850">

    <!-- SIDEBAR -->
    <left>
        <VBox spacing="12"
              prefWidth="240"
              style="-fx-background-color:#0f172a;">

            <padding>
                <Insets top="20" right="15" bottom="20" left="15"/>
            </padding>

            <children>

                <Label text="SAJILO POS"
                       style="-fx-font-size:24;
                              -fx-font-weight:bold;
                              -fx-text-fill:white;"/>

                <Label fx:id="sidebarCompanyLabel"
                       text="Company Name"
                       style="-fx-text-fill:#cbd5e1;
                              -fx-font-size:12;"/>

                <Separator/>

                <Button fx:id="dashboardMenu"
                        text="Dashboard"
                        onAction="#openDashboard"
                        prefHeight="40"
                        maxWidth="Infinity"/>

                <Button fx:id="productsMenu"
                        text="Products"
                        onAction="#openProducts"
                        prefHeight="40"
                        maxWidth="Infinity"/>

                <Button fx:id="customersMenu"
                        text="Customers"
                        onAction="#openCustomers"
                        prefHeight="40"
                        maxWidth="Infinity"/>

                <Button fx:id="inventoryMenu"
                        text="Inventory"
                        onAction="#openInventory"
                        prefHeight="40"
                        maxWidth="Infinity"/>

                <Button fx:id="purchasesMenu"
                        text="Purchases"
                        onAction="#openPurchases"
                        prefHeight="40"
                        maxWidth="Infinity"/>

                <Button fx:id="purchaseHistoryMenu"
                        text="Purchase History"
                        onAction="#openPurchaseHistory"
                        prefHeight="40"
                        maxWidth="Infinity"/>

                <Button fx:id="suppliersMenu"
                        text="Suppliers"
                        onAction="#openSuppliers"
                        prefHeight="40"
                        maxWidth="Infinity"/>

                <Button fx:id="salesMenu"
                        text="Sales"
                        onAction="#openSales"
                        prefHeight="40"
                        maxWidth="Infinity"/>

                <Button fx:id="reportsMenu"
                        text="Reports"
                        onAction="#openReports"
                        prefHeight="40"
                        maxWidth="Infinity"/>

                <Button fx:id="usersMenu"
                        text="Users"
                        onAction="#openUsers"
                        prefHeight="40"
                        maxWidth="Infinity"/>

                <Button fx:id="settingsMenu"
                        text="Settings"
                        onAction="#openSettings"
                        prefHeight="40"
                        maxWidth="Infinity"/>

                <Region VBox.vgrow="ALWAYS"/>

                <Button text="Logout"
                        onAction="#handleLogout"
                        prefHeight="40"
                        maxWidth="Infinity"
                        style="-fx-background-color:#dc2626;
                               -fx-text-fill:white;
                               -fx-font-weight:bold;"/>

            </children>
        </VBox>
    </left>

    <!-- TOP HEADER -->
    <top>
        <VBox spacing="5"
              style="-fx-background-color:white;
                     -fx-padding:15;
                     -fx-border-color:#e2e8f0;">

            <children>

                <Label text="SAJILO POS"
                       style="-fx-font-size:22;
                              -fx-font-weight:bold;"/>

                <Label fx:id="companyNameLabel"
                       text="Company Name"
                       style="-fx-font-size:18;
                              -fx-font-weight:bold;"/>

                <Label fx:id="roleLabel"
                       text="Logged in as: ADMIN"
                       style="-fx-font-size:14;
                              -fx-text-fill:#64748b;"/>

            </children>

        </VBox>
    </top>

    <!-- CENTER -->
    <center>

        <VBox spacing="20"
              style="-fx-background-color:#f1f5f9;
                     -fx-padding:20;">

            <!-- CARDS -->
            <HBox spacing="20">

                <VBox prefWidth="250"
                      prefHeight="120"
                      style="-fx-background-color:white;
                             -fx-background-radius:15;">
                    <children>
                        <Label text="Total Sales">
                            <VBox.margin><Insets top="20" left="20"/></VBox.margin>
                        </Label>

                        <Label fx:id="totalSalesLabel"
                               text="Rs. 0"
                               style="-fx-font-size:28;
                                      -fx-font-weight:bold;">
                            <VBox.margin><Insets top="10" left="20"/></VBox.margin>
                        </Label>
                    </children>
                </VBox>

                <VBox prefWidth="250"
                      prefHeight="120"
                      style="-fx-background-color:white;
                             -fx-background-radius:15;">
                    <children>
                        <Label text="Products">
                            <VBox.margin><Insets top="20" left="20"/></VBox.margin>
                        </Label>

                        <Label fx:id="productCountLabel"
                               text="0"
                               style="-fx-font-size:28;
                                      -fx-font-weight:bold;">
                            <VBox.margin><Insets top="10" left="20"/></VBox.margin>
                        </Label>
                    </children>
                </VBox>

                <VBox prefWidth="250"
                      prefHeight="120"
                      style="-fx-background-color:white;
                             -fx-background-radius:15;">
                    <children>
                        <Label text="Customers">
                            <VBox.margin><Insets top="20" left="20"/></VBox.margin>
                        </Label>

                        <Label fx:id="customerCountLabel"
                               text="0"
                               style="-fx-font-size:28;
                                      -fx-font-weight:bold;">
                            <VBox.margin><Insets top="10" left="20"/></VBox.margin>
                        </Label>
                    </children>
                </VBox>

                <VBox prefWidth="250"
                      prefHeight="120"
                      style="-fx-background-color:white;
                             -fx-background-radius:15;">
                    <children>
                        <Label text="Suppliers">
                            <VBox.margin><Insets top="20" left="20"/></VBox.margin>
                        </Label>

                        <Label fx:id="supplierCountLabel"
                               text="0"
                               style="-fx-font-size:28;
                                      -fx-font-weight:bold;">
                            <VBox.margin><Insets top="10" left="20"/></VBox.margin>
                        </Label>
                    </children>
                </VBox>

            </HBox>

            <!-- MAIN CONTENT -->
            <HBox spacing="20">

                <VBox prefWidth="850"
                      prefHeight="450"
                      style="-fx-background-color:white;
                             -fx-background-radius:15;">

                    <children>

                        <Label text="Recent Sales"
                               style="-fx-font-size:20;
                                      -fx-font-weight:bold;">
                            <VBox.margin>
                                <Insets top="20" left="20"/>
                            </VBox.margin>
                        </Label>

                        <TableView fx:id="recentSalesTable"
                                   prefHeight="400">
                        </TableView>

                    </children>

                </VBox>

                <VBox spacing="15"
                      prefWidth="250"
                      style="-fx-background-color:white;
                             -fx-background-radius:15;
                             -fx-padding:20;">

                    <children>

                        <Label text="Quick Actions"
                               style="-fx-font-size:18;
                                      -fx-font-weight:bold;"/>

                        <Button text="Add Product"
                                maxWidth="Infinity"/>

                        <Button text="Create Sale"
                                maxWidth="Infinity"/>

                        <Button text="Add Customer"
                                maxWidth="Infinity"/>

                        <Button text="Generate Report"
                                maxWidth="Infinity"/>

                    </children>

                </VBox>

            </HBox>

        </VBox>

    </center>

</BorderPane>