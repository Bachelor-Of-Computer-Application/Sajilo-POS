<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.possystem.sajilopos.controller.dashboard.DashboardController"
            fx:id="rootPane"
            prefWidth="1200.0"
            prefHeight="700.0">

    <!-- SIDEBAR -->
    <left>
        <VBox spacing="8"
              prefWidth="240"
              style="-fx-background-color:#0f172a;">

            <padding>
                <Insets top="24" right="15" bottom="20" left="15"/>
            </padding>

            <children>

                <Label text="SAJILO POS"
                       style="-fx-font-size:22;
                              -fx-font-weight:bold;
                              -fx-text-fill:white;"/>

                <Label fx:id="sidebarCompanyLabel"
                       text="Company Name"
                       style="-fx-text-fill:#94a3b8;
                              -fx-font-size:11;"/>

                <Separator style="-fx-background-color:#1e293b;"/>

                <Button fx:id="dashboardMenu"
                        text="Dashboard"
                        onAction="#openDashboard"
                        prefHeight="38"
                        maxWidth="Infinity"
                        style="-fx-background-color:#1e293b; -fx-text-fill:white; -fx-font-size:13; -fx-alignment:CENTER-LEFT; -fx-background-radius:6; -fx-cursor:hand;"/>

                <Button text="Products"
                        onAction="#openProducts"
                        prefHeight="38"
                        maxWidth="Infinity"
                        style="-fx-background-color:#1e293b; -fx-text-fill:white; -fx-font-size:13; -fx-alignment:CENTER-LEFT; -fx-background-radius:6; -fx-cursor:hand;"/>

                <Button fx:id="customersMenu"
                        text="Customers"
                        onAction="#openCustomers"
                        prefHeight="38"
                        maxWidth="Infinity"
                        style="-fx-background-color:#1e293b; -fx-text-fill:white; -fx-font-size:13; -fx-alignment:CENTER-LEFT; -fx-background-radius:6; -fx-cursor:hand;"/>

                <Button fx:id="inventoryMenu"
                        text="Inventory"
                        onAction="#openInventory"
                        prefHeight="38"
                        maxWidth="Infinity"
                        style="-fx-background-color:#1e293b; -fx-text-fill:white; -fx-font-size:13; -fx-alignment:CENTER-LEFT; -fx-background-radius:6; -fx-cursor:hand;"/>

                <Button fx:id="purchasesMenu"
                        text="Purchases"
                        onAction="#openPurchases"
                        prefHeight="38"
                        maxWidth="Infinity"
                        style="-fx-background-color:#1e293b; -fx-text-fill:white; -fx-font-size:13; -fx-alignment:CENTER-LEFT; -fx-background-radius:6; -fx-cursor:hand;"/>

                <Button fx:id="purchaseHistoryMenu"
                        text="Purchase History"
                        onAction="#openPurchaseHistory"
                        prefHeight="38"
                        maxWidth="Infinity"
                        style="-fx-background-color:#1e293b; -fx-text-fill:white; -fx-font-size:13; -fx-alignment:CENTER-LEFT; -fx-background-radius:6; -fx-cursor:hand;"/>

                <Button fx:id="suppliersMenu"
                        text="Suppliers"
                        onAction="#openSuppliers"
                        prefHeight="38"
                        maxWidth="Infinity"
                        style="-fx-background-color:#1e293b; -fx-text-fill:white; -fx-font-size:13; -fx-alignment:CENTER-LEFT; -fx-background-radius:6; -fx-cursor:hand;"/>

                <Button text="Sales"
                        onAction="#openSales"
                        prefHeight="38"
                        maxWidth="Infinity"
                        style="-fx-background-color:#1e293b; -fx-text-fill:white; -fx-font-size:13; -fx-alignment:CENTER-LEFT; -fx-background-radius:6; -fx-cursor:hand;"/>

                <Button fx:id="reportsMenu"
                        text="Reports"
                        onAction="#openReports"
                        prefHeight="38"
                        maxWidth="Infinity"
                        style="-fx-background-color:#1e293b; -fx-text-fill:white; -fx-font-size:13; -fx-alignment:CENTER-LEFT; -fx-background-radius:6; -fx-cursor:hand;"/>

                <Button fx:id="usersMenu"
                        text="Users"
                        onAction="#openUsers"
                        prefHeight="38"
                        maxWidth="Infinity"
                        style="-fx-background-color:#1e293b; -fx-text-fill:white; -fx-font-size:13; -fx-alignment:CENTER-LEFT; -fx-background-radius:6; -fx-cursor:hand;"/>

                <Button fx:id="settingsMenu"
                        text="Settings"
                        onAction="#openSettings"
                        prefHeight="38"
                        maxWidth="Infinity"
                        style="-fx-background-color:#1e293b; -fx-text-fill:white; -fx-font-size:13; -fx-alignment:CENTER-LEFT; -fx-background-radius:6; -fx-cursor:hand;"/>

                <Separator style="-fx-background-color:#1e293b;"/>

                <Button text="Logout"
                        onAction="#handleLogout"
                        prefHeight="38"
                        maxWidth="Infinity"
                        style="-fx-background-color:#dc2626; -fx-text-fill:white; -fx-font-size:13; -fx-font-weight:bold; -fx-alignment:CENTER-LEFT; -fx-background-radius:6; -fx-cursor:hand;"/>

            </children>
        </VBox>
    </left>

    <!-- TOP HEADER -->
    <top>
        <HBox prefHeight="64"
              alignment="CENTER_LEFT"
              spacing="12"
              style="-fx-background-color: white;
                     -fx-border-color: #e2e8f0;
                     -fx-border-width: 0 0 1 0;
                     -fx-padding: 0 24 0 24;">

            <children>

                <Label text="SAJILO POS"
                       style="-fx-font-size:20;
                              -fx-font-weight:bold;
                              -fx-text-fill:#0f172a;"/>

                <Label text="|"
                       style="-fx-font-size:18; -fx-text-fill:#cbd5e1;"/>

                <Label fx:id="companyNameLabel"
                       text="Company Name"
                       style="-fx-font-size:14;
                              -fx-text-fill:#475569;"/>

                <HBox HBox.hgrow="ALWAYS"/>

                <Label fx:id="roleLabel"
                       text="Logged in as: ADMIN"
                       style="-fx-font-size:13;
                              -fx-text-fill:#64748b;
                              -fx-background-color:#f1f5f9;
                              -fx-background-radius:20;
                              -fx-padding: 5 14 5 14;"/>

            </children>

        </HBox>
    </top>

    <!-- CENTER -->
    <center>
        <AnchorPane style="-fx-background-color: #f1f5f9;">

            <children>

                <!-- CARD 1 -->
                <VBox layoutX="40" layoutY="40"
                      prefWidth="220" prefHeight="120"
                      style="-fx-background-color: white; -fx-background-radius: 15;">

                    <children>
                        <Label text="Total Sales"
                               style="-fx-font-size: 14px;">
                            <VBox.margin>
                                <Insets top="20" left="20"/>
                            </VBox.margin>
                        </Label>

                        <Label text="Rs. 125000"
                               style="-fx-font-size: 28px; -fx-font-weight: bold;">
                            <VBox.margin>
                                <Insets top="10" left="20"/>
                            </VBox.margin>
                        </Label>
                    </children>
                </VBox>

                <!-- CARD 2 -->
                <VBox layoutX="300" layoutY="40"
                      prefWidth="220" prefHeight="120"
                      style="-fx-background-color: white; -fx-background-radius: 15;">

                    <children>
                        <Label text="Products">
                            <VBox.margin>
                                <Insets top="20" left="20"/>
                            </VBox.margin>
                        </Label>

                        <Label text="245"
                               style="-fx-font-size: 28px; -fx-font-weight: bold;">
                            <VBox.margin>
                                <Insets top="10" left="20"/>
                            </VBox.margin>
                        </Label>
                    </children>
                </VBox>

                <!-- CARD 3 -->
                <VBox layoutX="560" layoutY="40"
                      prefWidth="220" prefHeight="120"
                      style="-fx-background-color: white; -fx-background-radius: 15;">

                    <children>
                        <Label text="Customers">
                            <VBox.margin>
                                <Insets top="20" left="20"/>
                            </VBox.margin>
                        </Label>

                        <Label text="95"
                               style="-fx-font-size: 28px; -fx-font-weight: bold;">
                            <VBox.margin>
                                <Insets top="10" left="20"/>
                            </VBox.margin>
                        </Label>
                    </children>
                </VBox>

                <!-- RECENT SALES -->
                <VBox layoutX="40" layoutY="210"
                      prefWidth="740" prefHeight="300"
                      style="-fx-background-color: white; -fx-background-radius: 15;">

                    <children>
                        <Label text="Recent Sales"
                               style="-fx-font-size: 20px; -fx-font-weight: bold;">
                            <VBox.margin>
                                <Insets top="20" left="20"/>
                            </VBox.margin>
                        </Label>

                        <Label text="Invoice #1001 - Rs. 4500">
                            <VBox.margin>
                                <Insets top="20" left="20"/>
                            </VBox.margin>
                        </Label>

                        <Label text="Invoice #1002 - Rs. 7200">
                            <VBox.margin>
                                <Insets top="10" left="20"/>
                            </VBox.margin>
                        </Label>

                        <Label text="Invoice #1003 - Rs. 1500">
                            <VBox.margin>
                                <Insets top="10" left="20"/>
                            </VBox.margin>
                        </Label>

                    </children>
                </VBox>

                <!-- QUICK ACTIONS -->
                <VBox layoutX="820" layoutY="210"
                      prefWidth="250" prefHeight="300"
                      spacing="15"
                      style="-fx-background-color: white; -fx-background-radius: 15;">

                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>

                    <children>
                        <Label text="Quick Actions"
                               style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

                        <Button text="Add Product"/>
                        <Button text="Create Sale"/>
                        <Button text="Generate Report"/>
                    </children>

                </VBox>

            </children>
        </AnchorPane>
    </center>

</BorderPane>
