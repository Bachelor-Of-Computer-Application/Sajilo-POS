<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.possystem.sajilopos.controller.dashboard.DashboardController"
            fx:id="rootPane"
            prefWidth="1200.0"
            prefHeight="700.0">

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox spacing="15"
              prefWidth="230"
              style="-fx-background-color: #0f172a;">

            <padding>
                <Insets top="25" right="15" bottom="25" left="15"/>
            </padding>

            <children>

                <Label text="SAJILO POS"
                       style="-fx-text-fill: white;
                              -fx-font-size: 24px;
                              -fx-font-weight: bold;"/>

                <Separator/>

                <Button text="Dashboard" onAction="#openDashboard"
                        prefWidth="200" prefHeight="40"
                        style="-fx-background-color: #1e293b; -fx-text-fill: white;"/>

                <Button text="Products" onAction="#openProducts"
                        prefWidth="200" prefHeight="40"
                        style="-fx-background-color: #1e293b; -fx-text-fill: white;"/>

                <Button text="Customers" onAction="#openCustomers"
                        prefWidth="200" prefHeight="40"
                        style="-fx-background-color: #1e293b; -fx-text-fill: white;"/>

                <Button text="Inventory" onAction="#openInventory"
                        prefWidth="200" prefHeight="40"
                        style="-fx-background-color: #1e293b; -fx-text-fill: white;"/>

                <Button text="Purchases" onAction="#openPurchases"
                        prefWidth="200" prefHeight="40"
                        style="-fx-background-color: #1e293b; -fx-text-fill: white;"/>

                <Button text="Purchase History" onAction="#openPurchaseHistory"
                        prefWidth="200" prefHeight="40"
                        style="-fx-background-color: #1e293b; -fx-text-fill: white;"/>

                <Button text="Suppliers" onAction="#openSuppliers"
                        prefWidth="200" prefHeight="40"
                        style="-fx-background-color: #1e293b; -fx-text-fill: white;"/>

                <Button text="Sales" onAction="#openSales"
                        prefWidth="200" prefHeight="40"
                        style="-fx-background-color: #1e293b; -fx-text-fill: white;"/>

                <Button text="Reports" onAction="#openReports"
                        prefWidth="200" prefHeight="40"
                        style="-fx-background-color: #1e293b; -fx-text-fill: white;"/>

                <Button text="Users" onAction="#openUsers"
                        prefWidth="200" prefHeight="40"
                        style="-fx-background-color: #1e293b; -fx-text-fill: white;"/>

                <Button text="Settings" onAction="#openSettings"
                        prefWidth="200" prefHeight="40"
                        style="-fx-background-color: #1e293b; -fx-text-fill: white;"/>

            </children>
        </VBox>
    </left>

    <!-- TOP BAR -->
    <top>
        <HBox prefHeight="70"
              style="-fx-background-color: white; -fx-border-color: #e2e8f0;">

            <children>
                <Label text="Dashboard Overview"
                       style="-fx-font-size: 26px; -fx-font-weight: bold;">
                    <HBox.margin>
                        <Insets top="20" left="25"/>
                    </HBox.margin>
                </Label>
            </children>
        </HBox>
    </top>

    <!-- CENTER CONTENT -->
    <center>
        <AnchorPane style="-fx-background-color: #f1f5f9;">

            <children>

                <!-- CARD 1 -->
                <VBox layoutX="40" layoutY="40"
                      prefWidth="220" prefHeight="120"
                      style="-fx-background-color: white; -fx-background-radius: 15;">

                    <children>
                        <Label text="Total Sales"
                               style="-fx-font-size: 14px;">
                            <VBox.margin>
                                <Insets top="20" left="20"/>
                            </VBox.margin>
                        </Label>

                        <Label text="Rs. 125000"
                               style="-fx-font-size: 28px; -fx-font-weight: bold;">
                            <VBox.margin>
                                <Insets top="10" left="20"/>
                            </VBox.margin>
                        </Label>
                    </children>
                </VBox>

                <!-- CARD 2 -->
                <VBox layoutX="300" layoutY="40"
                      prefWidth="220" prefHeight="120"
                      style="-fx-background-color: white; -fx-background-radius: 15;">

                    <children>
                        <Label text="Products">
                            <VBox.margin>
                                <Insets top="20" left="20"/>
                            </VBox.margin>
                        </Label>

                        <Label text="245"
                               style="-fx-font-size: 28px; -fx-font-weight: bold;">
                            <VBox.margin>
                                <Insets top="10" left="20"/>
                            </VBox.margin>
                        </Label>
                    </children>
                </VBox>

                <!-- CARD 3 -->
                <VBox layoutX="560" layoutY="40"
                      prefWidth="220" prefHeight="120"
                      style="-fx-background-color: white; -fx-background-radius: 15;">

                    <children>
                        <Label text="Customers">
                            <VBox.margin>
                                <Insets top="20" left="20"/>
                            </VBox.margin>
                        </Label>

                        <Label text="95"
                               style="-fx-font-size: 28px; -fx-font-weight: bold;">
                            <VBox.margin>
                                <Insets top="10" left="20"/>
                            </VBox.margin>
                        </Label>
                    </children>
                </VBox>

                <!-- RECENT SALES -->
                <VBox layoutX="40" layoutY="210"
                      prefWidth="740" prefHeight="300"
                      style="-fx-background-color: white; -fx-background-radius: 15;">

                    <children>
                        <Label text="Recent Sales"
                               style="-fx-font-size: 20px; -fx-font-weight: bold;">
                            <VBox.margin>
                                <Insets top="20" left="20"/>
                            </VBox.margin>
                        </Label>

                        <Label text="Invoice #1001 - Rs. 4500">
                            <VBox.margin>
                                <Insets top="20" left="20"/>
                            </VBox.margin>
                        </Label>

                        <Label text="Invoice #1002 - Rs. 7200">
                            <VBox.margin>
                                <Insets top="10" left="20"/>
                            </VBox.margin>
                        </Label>

                        <Label text="Invoice #1003 - Rs. 1500">
                            <VBox.margin>
                                <Insets top="10" left="20"/>
                            </VBox.margin>
                        </Label>

                    </children>
                </VBox>

                <!-- QUICK ACTIONS -->
                <VBox layoutX="820" layoutY="210"
                      prefWidth="250" prefHeight="300"
                      spacing="15"
                      style="-fx-background-color: white; -fx-background-radius: 15;">

                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>

                    <children>
                        <Label text="Quick Actions"
                               style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

                        <Button text="Add Product"/>
                        <Button text="Create Sale"/>
                        <Button text="Generate Report"/>
                    </children>

                </VBox>

            </children>
        </AnchorPane>
    </center>

</BorderPane>