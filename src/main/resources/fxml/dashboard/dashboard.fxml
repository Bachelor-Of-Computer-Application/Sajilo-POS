<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.possystem.sajilopos.controller.dashboard.DashboardController"
            prefWidth="1200.0"
            prefHeight="700.0">

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox spacing="15"
              prefWidth="230"
              style="-fx-background-color: #0f172a;">

            <padding>
                <Insets top="25" right="15" bottom="25" left="15"/>
            </padding>

            <children>

                <Label text="SAJILO POS"
                       style="-fx-text-fill: white;
                              -fx-font-size: 24px;
                              -fx-font-weight: bold;"/>

                <Separator/>

                <Button text="Dashboard" onAction="#openDashboard"
                        prefWidth="200" prefHeight="40"
                        style="-fx-background-color: #1e293b; -fx-text-fill: white;"/>

                <Button text="Sales" onAction="#openSales"
                        prefWidth="200" prefHeight="40"
                        style="-fx-background-color: #1e293b; -fx-text-fill: white;"/>

                <Button text="Customers" onAction="#openCustomers"
                        prefWidth="200" prefHeight="40"
                        style="-fx-background-color: #1e293b; -fx-text-fill: white;"/>

                <Button fx:id="productsMenu" text="Products" onAction="#openProducts"
                        prefWidth="200" prefHeight="40"
                        style="-fx-background-color: #1e293b; -fx-text-fill: white;"/>

                <Button fx:id="inventoryMenu" text="Inventory" onAction="#openInventory"
                        prefWidth="200" prefHeight="40"
                        style="-fx-background-color: #1e293b; -fx-text-fill: white;"/>

                <Button fx:id="purchasesMenu" text="Purchases" onAction="#openPurchases"
                        prefWidth="200" prefHeight="40"
                        style="-fx-background-color: #1e293b; -fx-text-fill: white;"/>

                <Button text="Purchase History" onAction="#openPurchaseHistory"
                        prefWidth="200" prefHeight="40"
                        style="-fx-background-color: #1e293b; -fx-text-fill: white;"/>

                <Button fx:id="suppliersMenu" text="Suppliers" onAction="#openSuppliers"
                        prefWidth="200" prefHeight="40"
                        style="-fx-background-color: #1e293b; -fx-text-fill: white;"/>

                <Button fx:id="reportsMenu" text="Reports" onAction="#openReports"
                        prefWidth="200" prefHeight="40"
                        style="-fx-background-color: #1e293b; -fx-text-fill: white;"/>

                <Button fx:id="usersMenu" text="Users" onAction="#openUsers"
                        prefWidth="200" prefHeight="40"
                        style="-fx-background-color: #1e293b; -fx-text-fill: white;"/>

                <Button fx:id="settingsMenu" text="Settings" onAction="#openSettings"
                        prefWidth="200" prefHeight="40"
                        style="-fx-background-color: #1e293b; -fx-text-fill: white;"/>

            </children>
        </VBox>
    </left>

    <!-- TOP BAR -->
    <top>
        <HBox prefHeight="70"
              style="-fx-background-color: white; -fx-border-color: #e2e8f0;">
            <children>
                <Label text="Dashboard Overview"
                       style="-fx-font-size: 26px; -fx-font-weight: bold;">
                    <HBox.margin>
                        <Insets top="20" left="25"/>
                    </HBox.margin>
                </Label>
            </children>
        </HBox>
    </top>

    <!-- CENTER CONTENT -->
    <center>
        <BorderPane fx:id="rootPane" style="-fx-background-color: #f1f5f9;"/>
    </center>

</BorderPane>
