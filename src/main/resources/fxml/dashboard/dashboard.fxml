<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            prefWidth="1200.0"
            prefHeight="700.0">

    <!-- SIDEBAR -->

    <left>

        <VBox prefWidth="230"
              spacing="15"
              style="-fx-background-color: #0f172a;">

            <padding>
                <Insets top="25" right="15" bottom="25" left="15"/>
            </padding>

            <children>

                <Label text="SAJILO POS"
                       style="-fx-text-fill: white;
                              -fx-font-size: 26px;
                              -fx-font-weight: bold;"/>

                <Separator/>

                <Button text="Dashboard"
                        prefHeight="40"
                        prefWidth="200"
                        style="-fx-background-color: #1e293b;
                               -fx-text-fill: white;
                               -fx-font-size: 14px;"/>

                <Button text="Products"
                        prefHeight="40"
                        prefWidth="200"
                        style="-fx-background-color: #1e293b;
                               -fx-text-fill: white;
                               -fx-font-size: 14px;"/>

                <Button text="Sales"
                        prefHeight="40"
                        prefWidth="200"
                        style="-fx-background-color: #1e293b;
                               -fx-text-fill: white;
                               -fx-font-size: 14px;"/>

                <Button text="Customers"
                        prefHeight="40"
                        prefWidth="200"
                        style="-fx-background-color: #1e293b;
                               -fx-text-fill: white;
                               -fx-font-size: 14px;"/>

                <Button text="Reports"
                        prefHeight="40"
                        prefWidth="200"
                        style="-fx-background-color: #1e293b;
                               -fx-text-fill: white;
                               -fx-font-size: 14px;"/>

                <Button text="Settings"
                        prefHeight="40"
                        prefWidth="200"
                        style="-fx-background-color: #1e293b;
                               -fx-text-fill: white;
                               -fx-font-size: 14px;"/>

            </children>

        </VBox>

    </left>

    <!-- TOP BAR -->

    <top>

        <HBox prefHeight="70"
              style="-fx-background-color: white;
                     -fx-border-color: #e2e8f0;">

            <children>

                <Label text="Dashboard Overview"
                       style="-fx-font-size: 28px;
                              -fx-font-weight: bold;">

                    <HBox.margin>
                        <Insets top="20" left="25"/>
                    </HBox.margin>

                </Label>

            </children>

        </HBox>

    </top>

    <!-- CENTER CONTENT -->

    <center>

        <AnchorPane style="-fx-background-color: #f1f5f9;">

            <children>

                <!-- CARD 1 -->

                <VBox layoutX="40"
                      layoutY="40"
                      prefWidth="220"
                      prefHeight="120"
                      style="-fx-background-color: white;
                             -fx-background-radius: 15;">

                    <children>

                        <Label text="Total Sales">

                            <VBox.margin>
                                <Insets top="20" left="20"/>
                            </VBox.margin>

                        </Label>

                        <Label text="Rs. 125000"
                               style="-fx-font-size: 30px;
                                      -fx-font-weight: bold;">

                            <VBox.margin>
                                <Insets top="10" left="20"/>
                            </VBox.margin>

                        </Label>

                    </children>

                </VBox>

                <!-- CARD 2 -->

                <VBox layoutX="300"
                      layoutY="40"
                      prefWidth="220"
                      prefHeight="120"
                      style="-fx-background-color: white;
                             -fx-background-radius: 15;">

                    <children>

                        <Label text="Products">

                            <VBox.margin>
                                <Insets top="20" left="20"/>
                            </VBox.margin>

                        </Label>

                        <Label text="245"
                               style="-fx-font-size: 30px;
                                      -fx-font-weight: bold;">

                            <VBox.margin>
                                <Insets top="10" left="20"/>
                            </VBox.margin>

                        </Label>

                    </children>

                </VBox>

                <!-- CARD 3 -->

                <VBox layoutX="560"
                      layoutY="40"
                      prefWidth="220"
                      prefHeight="120"
                      style="-fx-background-color: white;
                             -fx-background-radius: 15;">

                    <children>

                        <Label text="Customers">

                            <VBox.margin>
                                <Insets top="20" left="20"/>
                            </VBox.margin>

                        </Label>

                        <Label text="95"
                               style="-fx-font-size: 30px;
                                      -fx-font-weight: bold;">

                            <VBox.margin>
                                <Insets top="10" left="20"/>
                            </VBox.margin>

                        </Label>

                    </children>

                </VBox>

                <!-- RECENT SALES PANEL -->

                <VBox layoutX="40"
                      layoutY="210"
                      prefWidth="740"
                      prefHeight="300"
                      style="-fx-background-color: white;
                             -fx-background-radius: 15;">

                    <children>

                        <Label text="Recent Sales"
                               style="-fx-font-size: 22px;
                                      -fx-font-weight: bold;">

                            <VBox.margin>
                                <Insets top="20" left="20"/>
                            </VBox.margin>

                        </Label>

                        <Label text="Invoice #1001   -   Rs. 4500">

                            <VBox.margin>
                                <Insets top="20" left="20"/>
                            </VBox.margin>

                        </Label>

                        <Label text="Invoice #1002   -   Rs. 7200">

                            <VBox.margin>
                                <Insets top="10" left="20"/>
                            </VBox.margin>

                        </Label>

                        <Label text="Invoice #1003   -   Rs. 1500">

                            <VBox.margin>
                                <Insets top="10" left="20"/>
                            </VBox.margin>

                        </Label>

                    </children>

                </VBox>

                <!-- QUICK ACTIONS -->

                <VBox layoutX="820"
                      layoutY="210"
                      prefWidth="250"
                      prefHeight="300"
                      spacing="15"
                      style="-fx-background-color: white;
                             -fx-background-radius: 15;">

                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>

                    <children>

                        <Label text="Quick Actions"
                               style="-fx-font-size: 22px;
                                      -fx-font-weight: bold;"/>

                        <Button text="Add Product"
                                prefHeight="40"/>

                        <Button text="Create Sale"
                                prefHeight="40"/>

                        <Button text="Generate Report"
                                prefHeight="40"/>

                    </children>

                </VBox>

            </children>

        </AnchorPane>

    </center>

</BorderPane>