<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.possystem.sajilopos.controller.product.ProductController"
            prefWidth="1000" prefHeight="700"
            style="-fx-background-color: #f1f5f9;">

    <!-- TOP HEADER -->
    <top>
        <HBox prefHeight="70" style="-fx-background-color: white; -fx-border-color: #e2e8f0;">
            <children>
                <Label text="Product Management"
                       style="-fx-font-size: 26px; -fx-font-weight: bold;">
                    <HBox.margin>
                        <Insets top="20" left="25"/>
                    </HBox.margin>
                </Label>
                
                <!-- Search Bar -->
                <HBox spacing="10" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                    <HBox.margin>
                        <Insets top="15" left="100" right="25"/>
                    </HBox.margin>
                    <TextField fx:id="searchField" promptText="Search products..." prefWidth="300"/>
                    <Button text="Search" onAction="#handleSearch" 
                            style="-fx-background-color: #3b82f6; -fx-text-fill: white;"/>
                    <Button text="Refresh" onAction="#handleRefresh"
                            style="-fx-background-color: #10b981; -fx-text-fill: white;"/>
                </HBox>
            </children>
        </HBox>
    </top>

    <!-- LEFT FORM -->
    <left>
        <VBox spacing="15" prefWidth="320" style="-fx-background-color: white; -fx-padding: 20;">

            <children>
                <Label text="Product Details" 
                       style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                
                <Separator/>

                <Label text="Product Name" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                <TextField fx:id="nameField" promptText="Enter product name"
                           style="-fx-pref-height: 35px;"/>

                <Label text="Price (Rs.)" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                <TextField fx:id="priceField" promptText="0.00"
                           style="-fx-pref-height: 35px;"/>

                <Label text="Stock Quantity" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                <TextField fx:id="stockField" promptText="0"
                           style="-fx-pref-height: 35px;"/>

                <Label text="Description" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                <TextArea fx:id="descriptionArea" promptText="Enter product description..."
                          prefRowCount="4" wrapText="true"/>

                <Separator/>

                <HBox spacing="10">
                    <children>
                        <Button text="Add" onAction="#handleAdd" prefWidth="140" prefHeight="40"
                                style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <Button text="Clear" onAction="#handleClear" prefWidth="140" prefHeight="40"
                                style="-fx-background-color: #94a3b8; -fx-text-fill: white; -fx-font-size: 14px;"/>
                    </children>
                </HBox>

                <HBox spacing="10">
                    <children>
                        <Button text="Update" onAction="#handleUpdate" prefWidth="140" prefHeight="40"
                                style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <Button text="Delete" onAction="#handleDelete" prefWidth="140" prefHeight="40"
                                style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                    </children>
                </HBox>

                <VBox spacing="8" style="-fx-background-color: #f8fafc; -fx-padding: 15; -fx-background-radius: 8;">
                    <children>
                        <Label text="Instructions:" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                        <Label text="• Select a product from the table to edit" style="-fx-font-size: 11px;" wrapText="true"/>
                        <Label text="• Fill the form and click Add for new product" style="-fx-font-size: 11px;" wrapText="true"/>
                        <Label text="• Update modifies the selected product" style="-fx-font-size: 11px;" wrapText="true"/>
                        <Label text="• Delete removes the selected product" style="-fx-font-size: 11px;" wrapText="true"/>
                    </children>
                </VBox>

            </children>
        </VBox>
    </left>

    <!-- CENTER TABLE -->
    <center>
        <VBox style="-fx-padding: 20;">
            <children>
                <Label text="Product List" 
                       style="-fx-font-size: 16px; -fx-font-weight: bold;">
                    <VBox.margin>
                        <Insets bottom="10"/>
                    </VBox.margin>
                </Label>

                <TableView fx:id="productTable" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: white;">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                        <TableColumn fx:id="colName" text="Product Name" prefWidth="200"/>
                        <TableColumn fx:id="colPrice" text="Price (Rs.)" prefWidth="120"/>
                        <TableColumn fx:id="colStock" text="Stock" prefWidth="100"/>
                        <TableColumn fx:id="colDescription" text="Description" prefWidth="300"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </center>

</BorderPane>