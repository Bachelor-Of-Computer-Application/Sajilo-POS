<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.possystem.sajilopos.controller.product.ProductController"
            prefWidth="1100" prefHeight="700"
            style="-fx-background-color: #f1f5f9;">

    <!-- TOP HEADER -->
    <top>
        <HBox prefHeight="70" alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-padding: 0 25 0 25;">
            <Label text="Product Management"
                   style="-fx-font-size: 26px; -fx-font-weight: bold;"/>

            <HBox HBox.hgrow="ALWAYS"/>

            <!-- Category filter -->
            <Label text="Filter:" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
            <ComboBox fx:id="filterCategoryCombo" prefWidth="180" prefHeight="35"
                      promptText="All Categories"/>

            <!-- Search -->
            <TextField fx:id="searchField" promptText="Search products..." prefWidth="220" prefHeight="35"/>
            <Button text="Search"  onAction="#handleSearch"
                    style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-pref-height: 35px;"/>
            <Button text="Refresh" onAction="#handleRefresh"
                    style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-pref-height: 35px;"/>
        </HBox>
    </top>

    <!-- LEFT FORM -->
    <left>
        <VBox spacing="12" prefWidth="320"
              style="-fx-background-color: white; -fx-padding: 20;">

            <Label text="Product Details"
                   style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Separator/>

            <Label text="Category" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
            <ComboBox fx:id="categoryCombo" prefWidth="280" prefHeight="35"
                      promptText="Select category..."/>

            <Label text="Product Name" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
            <TextField fx:id="nameField" promptText="Enter product name"
                       style="-fx-pref-height: 35px;"/>

            <Label text="Price (Rs.)" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
            <TextField fx:id="priceField" promptText="0.00"
                       style="-fx-pref-height: 35px;"/>

            <Label text="Stock Quantity" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
            <TextField fx:id="stockField" promptText="0"
                       style="-fx-pref-height: 35px;"/>

            <Label text="Description" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
            <TextArea fx:id="descriptionArea" promptText="Enter product description..."
                      prefRowCount="4" wrapText="true"/>

            <Separator/>

            <HBox spacing="10">
                <Button text="Add"   onAction="#handleAdd"    prefWidth="134" prefHeight="40"
                        style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold;"/>
                <Button text="Clear" onAction="#handleClear"  prefWidth="134" prefHeight="40"
                        style="-fx-background-color: #94a3b8; -fx-text-fill: white;"/>
            </HBox>

            <HBox spacing="10">
                <Button text="Update" onAction="#handleUpdate" prefWidth="134" prefHeight="40"
                        style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold;"/>
                <Button text="Delete" onAction="#handleDelete" prefWidth="134" prefHeight="40"
                        style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold;"/>
            </HBox>

        </VBox>
    </left>

    <!-- CENTER TABLE -->
    <center>
        <VBox style="-fx-padding: 20;" spacing="10">
            <Label text="Product List"
                   style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

            <TableView fx:id="productTable" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: white;">
                <columns>
                    <TableColumn fx:id="colId"          text="ID"           prefWidth="55"/>
                    <TableColumn fx:id="colName"         text="Product Name" prefWidth="200"/>
                    <TableColumn fx:id="colCategory"     text="Category"     prefWidth="130"/>
                    <TableColumn fx:id="colPrice"        text="Price (Rs.)"  prefWidth="110"/>
                    <TableColumn fx:id="colStock"        text="Stock"        prefWidth="80"/>
                    <TableColumn fx:id="colDescription"  text="Description"  prefWidth="250"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>
    </center>

</BorderPane>
