<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.possystem.sajilopos.controller.customers.CustomerController"
            prefWidth="1000" prefHeight="700"
            style="-fx-background-color: #f1f5f9;">

    <!-- TOP HEADER -->
    <top>
        <HBox prefHeight="70" style="-fx-background-color: white; -fx-border-color: #e2e8f0;">
            <children>
                <Label text="Customer Management"
                       style="-fx-font-size: 26px; -fx-font-weight: bold;">
                    <HBox.margin>
                        <Insets top="20" left="25"/>
                    </HBox.margin>
                </Label>
                
                <!-- Search Bar -->
                <HBox spacing="10" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                    <HBox.margin>
                        <Insets top="15" left="100" right="25"/>
                    </HBox.margin>
                    <TextField fx:id="searchField" promptText="Search by name or phone..." prefWidth="300"/>
                    <Button text="Search" onAction="#handleSearch" 
                            style="-fx-background-color: #3b82f6; -fx-text-fill: white;"/>
                    <Button text="Refresh" onAction="#handleRefresh"
                            style="-fx-background-color: #10b981; -fx-text-fill: white;"/>
                </HBox>
            </children>
        </HBox>
    </top>

    <!-- LEFT FORM -->
    <left>
        <VBox spacing="15" prefWidth="320" style="-fx-background-color: white; -fx-padding: 20;">

            <children>
                <Label text="Customer Details" 
                       style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                
                <Separator/>

                <Label text="Customer Name" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                <TextField fx:id="nameField" promptText="Enter customer name"
                           style="-fx-pref-height: 35px;"/>

                <Label text="Phone Number" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                <TextField fx:id="phoneField" promptText="Enter phone number"
                           style="-fx-pref-height: 35px;"/>

                <Label text="Address" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                <TextArea fx:id="addressArea" promptText="Enter customer address..."
                          prefRowCount="3" wrapText="true"/>

                <Label text="Loyalty Points (Auto-calculated)" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                <TextField fx:id="loyaltyField" promptText="0" text="0" editable="false"
                           style="-fx-pref-height: 35px; -fx-background-color: #f1f5f9; -fx-opacity: 0.7;"/>

                <Separator/>

                <HBox spacing="10">
                    <children>
                        <Button text="Add" onAction="#handleAdd" prefWidth="140" prefHeight="40"
                                style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <Button text="Clear" onAction="#handleClear" prefWidth="140" prefHeight="40"
                                style="-fx-background-color: #94a3b8; -fx-text-fill: white; -fx-font-size: 14px;"/>
                    </children>
                </HBox>

                <HBox spacing="10">
                    <children>
                        <Button text="Update" onAction="#handleUpdate" prefWidth="140" prefHeight="40"
                                style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <Button text="Delete" onAction="#handleDelete" prefWidth="140" prefHeight="40"
                                style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                    </children>
                </HBox>

                <!-- <VBox spacing="8" style="-fx-background-color: #fff3cd; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #ffc107; -fx-border-width: 1; -fx-border-radius: 8;">
                    <children>
                        <Label text="⭐ Loyalty Points Info:" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #856404;"/>
                        <Label text="• Points are automatically calculated" style="-fx-font-size: 11px; -fx-text-fill: #856404;" wrapText="true"/>
                        <Label text="• Earn 1 point for every Rs. 100 spent" style="-fx-font-size: 11px; -fx-text-fill: #856404;" wrapText="true"/>
                        <Label text="• Points added when sale is completed" style="-fx-font-size: 11px; -fx-text-fill: #856404;" wrapText="true"/>
                    </children>
                </VBox> -->

                <VBox spacing="8" style="-fx-background-color: #f8fafc; -fx-padding: 15; -fx-background-radius: 8;">
                    <children>
                        <Label text="Instructions:" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                        <Label text="• Select a customer from the table to edit" style="-fx-font-size: 11px;" wrapText="true"/>
                        <Label text="• Fill the form and click Add for new customer" style="-fx-font-size: 11px;" wrapText="true"/>
                        <Label text="• Update modifies the selected customer" style="-fx-font-size: 11px;" wrapText="true"/>
                        <Label text="• Delete removes the selected customer" style="-fx-font-size: 11px;" wrapText="true"/>
                        <Label text="• Phone number must be unique" style="-fx-font-size: 11px;" wrapText="true"/>
                    </children>
                </VBox>

            </children>
        </VBox>
    </left>

    <!-- CENTER TABLE -->
    <center>
        <VBox style="-fx-padding: 20;">
            <children>
                <Label text="Customer List" 
                       style="-fx-font-size: 16px; -fx-font-weight: bold;">
                    <VBox.margin>
                        <Insets bottom="10"/>
                    </VBox.margin>
                </Label>

                <TableView fx:id="customerTable" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: white;">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                        <TableColumn fx:id="colName" text="Customer Name" prefWidth="200"/>
                        <TableColumn fx:id="colPhone" text="Phone" prefWidth="150"/>
                        <TableColumn fx:id="colAddress" text="Address" prefWidth="250"/>
                        <TableColumn fx:id="colLoyalty" text="Loyalty Points" prefWidth="120"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </center>

</BorderPane>