<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="500.0" prefWidth="800.0"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.possystem.sajilopos.controller.auth.LoginController">

    <children>

        <HBox prefHeight="500.0" prefWidth="800.0">

            <!-- LEFT PANEL -->
            <VBox alignment="CENTER" prefWidth="400"
                  style="-fx-background-color: linear-gradient(to bottom right, #4facfe, #00f2fe);">

                <children>
                    <Label style="-fx-font-size: 35px; -fx-font-weight: bold; -fx-text-fill: white;" 
                           text="SAJILO POS" />
                    <Label style="-fx-text-fill: white; -fx-font-size: 16px;" 
                           text="General POS System" />
                </children>

            </VBox>

            <!-- RIGHT PANEL -->
            <VBox alignment="CENTER" prefWidth="400" spacing="15">

                <padding>
                    <Insets bottom="40" left="40" right="40" top="40" />
                </padding>

                <children>
                    <Label style="-fx-font-size: 28px; -fx-font-weight: bold;" 
                           text="Login" />

                    <TextField fx:id="companyCodeField" 
                              prefWidth="250" 
                              promptText="Company Code (e.g., GPS001)" />

                    <TextField fx:id="usernameField" 
                              prefWidth="250" 
                              promptText="Username" />

                    <PasswordField fx:id="passwordField" 
                                  prefWidth="250" 
                                  promptText="Password" />

                    <Button onAction="#handleLogin" 
                           prefWidth="250" 
                           style="-fx-background-color: #4facfe; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" 
                           text="Login" />

                </children>

            </VBox>

        </HBox>

    </children>

</AnchorPane>
