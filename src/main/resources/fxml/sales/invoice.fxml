<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.possystem.sajilopos.controller.sales.InvoiceController"
      fx:id="receiptPane"
      spacing="10"
      style="-fx-background-color: white; -fx-padding: 20;"
      prefWidth="360" prefHeight="520">
    <children>
        <Label fx:id="businessNameLabel" text="SAJILO POS"
               style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
        <Label fx:id="businessAddressLabel" text="General POS Store"
               style="-fx-font-size: 12px;"/>
        <HBox spacing="10">
            <Label text="Invoice:" style="-fx-font-weight: bold;"/>
            <Label fx:id="invoiceNoLabel" text="INV-001"/>
        </HBox>
        <HBox spacing="10">
            <Label text="Date:" style="-fx-font-weight: bold;"/>
            <Label fx:id="saleDateLabel" text=""/>
        </HBox>
        <HBox spacing="10">
            <Label text="Customer:" style="-fx-font-weight: bold;"/>
            <Label fx:id="customerLabel" text="Walk-in Customer"/>
        </HBox>
        <HBox spacing="10">
            <Label text="Cashier:" style="-fx-font-weight: bold;"/>
            <Label fx:id="cashierLabel" text=""/>
        </HBox>
        <VBox fx:id="itemsContainer" spacing="4" style="-fx-padding: 8 0 0 0;"/>
        <HBox spacing="10">
            <Label text="Subtotal:" style="-fx-font-weight: bold;"/>
            <Label fx:id="subtotalLabel" text="Rs. 0.00"/>
        </HBox>
        <HBox spacing="10">
            <Label text="Discount:" style="-fx-font-weight: bold;"/>
            <Label fx:id="discountLabel" text="- Rs. 0.00"/>
        </HBox>
        <HBox spacing="10">
            <Label text="Grand Total:" style="-fx-font-weight: bold;"/>
            <Label fx:id="finalTotalLabel" text="Rs. 0.00"/>
        </HBox>
        <HBox spacing="10">
            <Label text="Payment:" style="-fx-font-weight: bold;"/>
            <Label fx:id="paymentMethodLabel" text=""/>
        </HBox>
        <HBox spacing="10">
            <Label text="Amount Paid:" style="-fx-font-weight: bold;"/>
            <Label fx:id="amountPaidLabel" text="Rs. 0.00"/>
        </HBox>
        <HBox spacing="10">
            <Label text="Change:" style="-fx-font-weight: bold;"/>
            <Label fx:id="changeLabel" text="Rs. 0.00"/>
        </HBox>
        <HBox fx:id="pointsRow" spacing="10" visible="false" managed="false">
            <Label fx:id="pointsEarnedLabel" text=""/>
        </HBox>
        <HBox spacing="10">
            <Button text="Print" onAction="#handlePrint"/>
            <Button text="Close" onAction="#handleClose"/>
        </HBox>
    </children>
</VBox>
