<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.possystem.sajilopos.controller.settings.settingscontroller"
            fitToWidth="true"
            style="-fx-background: #f1f5f9;">

    <content>

        <VBox spacing="20" style="-fx-padding: 20;">

            <!-- TITLE -->
            <Label text="Settings"
                   style="-fx-font-size: 28px; -fx-font-weight: bold;"/>

            <!-- ACCOUNT SECTION -->
            <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10;">
                <Label text="Account Settings" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

                <TextField fx:id="usernameField" promptText="Username"/>
                <PasswordField fx:id="passwordField" promptText="Password"/>

                <Button text="Update Account" onAction="#updateAccount"/>
            </VBox>

            <!-- SYSTEM SECTION -->
            <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10;">
                <Label text="System Settings" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

                <ChoiceBox fx:id="themeChoice"/>
                <CheckBox fx:id="taxCheck" text="Enable Tax"/>
                <CheckBox fx:id="discountCheck" text="Enable Discount System"/>

                <Button text="Save System Settings" onAction="#saveSystemSettings"/>
            </VBox>

            <!-- SECURITY SECTION -->
            <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10;">
                <Label text="Security" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

                <Button text="Change Password" onAction="#changePassword"/>
                <Button text="Enable 2FA" onAction="#enable2FA"/>
            </VBox>

            <!-- BACKUP SECTION -->
            <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10;">
                <Label text="Backup Restore" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

                <Button text="Backup Database" onAction="#backupDatabase"/>
                <Button text="Restore Database" onAction="#restoreDatabase"/>
            </VBox>

            <!-- SYSTEM ACTIONS -->
            <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10;">
                <Label text="System Actions" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

                <Button text="Clear Cache" onAction="#clearCache"/>
                <Button text="Reset System" onAction="#resetSystem" style="-fx-background-color: #ef4444; -fx-text-fill: white;"/>
            </VBox>

        </VBox>

    </content>

</ScrollPane>